#!/usr/bin/env python3

import argparse
import json
import subprocess
from http.server import BaseHTTPRequestHandler, ThreadingHTTPServer
from pathlib import Path


ROOT = Path(__file__).resolve().parent.parent
INDEX_HTML = ROOT / "web" / "index.html"
AGENT_SESSIONS = ROOT / "bin" / "agent-sessions"
FALLBACK_HTML = """<!doctype html>
<html lang="ja">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Agent Sessions</title>
  <style>
    body { margin: 0; font-family: ui-sans-serif, system-ui, sans-serif; background: #f6f2eb; color: #2e261d; }
    main { max-width: 1100px; margin: 24px auto; padding: 20px; background: #fffaf4; border: 1px solid #d9cbb9; border-radius: 18px; }
    h1 { margin: 0 0 6px; font-size: 32px; }
    p { margin: 0 0 18px; color: #6b5a46; }
    table { width: 100%; border-collapse: collapse; }
    th, td { padding: 12px; border-bottom: 1px solid #eadfce; text-align: left; vertical-align: top; }
    th { font-size: 12px; color: #6b5a46; text-transform: uppercase; }
    .cwd { font-size: 12px; color: #6b5a46; word-break: break-all; }
    .badge { display: inline-block; border-radius: 999px; padding: 4px 10px; border: 1px solid currentColor; font-size: 12px; }
    .busy { color: #b54d2d; } .busyq { color: #d17828; } .idle { color: #2f6f57; } .idleq { color: #4d8b77; } .stopped { color: #7f5af0; } .daemon { color: #8b6f47; }
  </style>
</head>
<body>
  <main>
    <h1>Agent Sessions</h1>
    <p>2 秒ごとに自動更新します。</p>
    <table>
      <thead>
        <tr><th>Tool</th><th>Status</th><th>Project</th><th>TTY</th><th>CPU</th><th>Elapsed</th><th>PID</th><th>Source</th></tr>
      </thead>
      <tbody id="rows"><tr><td colspan="8">Loading...</td></tr></tbody>
    </table>
  </main>
  <script>
    const rows = document.getElementById("rows");
    const cls = (status) => ({ "busy":"busy", "busy?":"busyq", "idle":"idle", "idle?":"idleq", "stopped":"stopped", "daemon":"daemon" }[status] || "idle");
    async function load() {
      const res = await fetch("/api/sessions?t=" + Date.now(), { cache: "no-store" });
      const data = await res.json();
      rows.innerHTML = data.map((item) => `
        <tr>
          <td>${item.tool}</td>
          <td><span class="badge ${cls(item.status)}">${item.status}</span></td>
          <td><div>${item.project || "-"}</div><div class="cwd">${item.cwd || "-"}</div></td>
          <td>${item.tty}</td>
          <td>${item.cpu}%</td>
          <td>${item.elapsed}</td>
          <td>${item.pid}</td>
          <td>${item.source}</td>
        </tr>
      `).join("") || '<tr><td colspan="8">No sessions found.</td></tr>';
    }
    load();
    setInterval(load, 2000);
  </script>
</body>
</html>
"""


class Handler(BaseHTTPRequestHandler):
    def do_GET(self):
        if self.path == "/" or self.path.startswith("/?"):
            self._send_html()
            return
        if self.path.startswith("/api/sessions"):
            self._send_sessions()
            return
        self.send_error(404)

    def log_message(self, fmt, *args):
        return

    def _send_html(self):
        if INDEX_HTML.exists():
            body = INDEX_HTML.read_bytes()
        else:
            body = FALLBACK_HTML.encode("utf-8")
        self.send_response(200)
        self.send_header("Content-Type", "text/html; charset=utf-8")
        self.send_header("Content-Length", str(len(body)))
        self.end_headers()
        self.wfile.write(body)

    def _send_sessions(self):
        try:
            completed = subprocess.run(
                [str(AGENT_SESSIONS), "--json"],
                check=True,
                capture_output=True,
                text=True,
            )
            payload = json.loads(completed.stdout)
            body = json.dumps(payload).encode("utf-8")
            self.send_response(200)
            self.send_header("Content-Type", "application/json; charset=utf-8")
            self.send_header("Cache-Control", "no-store")
            self.send_header("Content-Length", str(len(body)))
            self.end_headers()
            self.wfile.write(body)
        except Exception as exc:  # pragma: no cover
            body = json.dumps({"error": str(exc)}).encode("utf-8")
            self.send_response(500)
            self.send_header("Content-Type", "application/json; charset=utf-8")
            self.send_header("Content-Length", str(len(body)))
            self.end_headers()
            self.wfile.write(body)


def main():
    parser = argparse.ArgumentParser(description="Serve a local web UI for agent sessions")
    parser.add_argument("--host", default="127.0.0.1")
    parser.add_argument("--port", type=int, default=8765)
    args = parser.parse_args()

    server = ThreadingHTTPServer((args.host, args.port), Handler)
    print(f"agent-sessions-web listening on http://{args.host}:{args.port}")
    try:
        server.serve_forever()
    except KeyboardInterrupt:
        pass
    finally:
        server.server_close()


if __name__ == "__main__":
    main()
