{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Agent Sessions",
  "version": "0.1.0",
  "identifier": "com.elzup.agentsessions",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Agent Sessions",
        "width": 1240,
        "height": 860,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "app"
  }
}
